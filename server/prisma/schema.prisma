generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}

model Client {
  id                Int                @id @default(autoincrement())
  name              String
  regNumber         String?
  phoneNumber       String
  phoneNumber2      String?
  email             String?
  paymentType       PaymentType        @default(rent)
  status            ClientStatus       @default(active)
  domain            String?
  notes             String?
  productType       String?
  systemId          Int?
  system            System?            @relation(fields: [systemId], references: [id])
  isConnected       Boolean            @default(false)
  rentalAgreement   RentalAgreement?
  purchaseAgreement PurchaseAgreement?
  invoices          Invoice[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("clients")
}

model RentalAgreement {
  id                 Int                   @id @default(autoincrement())
  clientId           Int                   @unique
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status             RentalAgreementStatus @default(active)
  cancelledAt        DateTime?
  leaseStartAt       DateTime              @default(now())
  rentDurationMonths Int                   @default(12)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  paymentSchedules   PaymentSchedule[]

  @@map("rental_agreements")
}

model PurchaseAgreement {
  id            Int                     @id @default(autoincrement())
  clientId      Int                     @unique
  client        Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  totalPrice    Float
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  installments  PurchaseInstallment[]

  @@map("purchase_agreements")
}

model PurchaseInstallment {
  id                  Int               @id @default(autoincrement())
  purchaseAgreementId Int
  purchaseAgreement   PurchaseAgreement @relation(fields: [purchaseAgreementId], references: [id], onDelete: Cascade)
  dueDate             DateTime
  amount              Float
  sortOrder           Int               @default(0)
  invoice             Invoice?

  @@map("purchase_installments")
}

model Invoice {
  id                      Int                  @id @default(autoincrement())
  invoiceNumber           String               @unique
  publicToken             String               @unique
  clientId                Int
  client                  Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount                  Float
  description             String?
  status                  InvoiceStatus        @default(pending)
  issuedAt                DateTime             @default(now())
  dueDate                 DateTime
  paidAt                  DateTime?
  scheduleDay             Int
  scheduleMonth           Int
  scheduleYear            Int
  rentPeriodKey           String?              @unique
  purchaseInstallmentId   Int?                 @unique
  purchaseInstallment     PurchaseInstallment? @relation(fields: [purchaseInstallmentId], references: [id], onDelete: SetNull)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@map("invoices")
}

model PaymentSchedule {
  id                Int             @id @default(autoincrement())
  rentalAgreementId Int
  rentalAgreement   RentalAgreement @relation(fields: [rentalAgreementId], references: [id], onDelete: Cascade)
  day               Int
  amount            Float

  @@map("payment_schedules")
}

model System {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  photo     String?
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[]

  @@map("systems")
}

model Module {
  id        Int      @id @default(autoincrement())
  title      String
  code      String
  isEnabled Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans Plan[]

  @@map("modules")
}

model Plan {
  id        Int      @id @default(autoincrement())
  moduleId    Int
  module      Module   @relation(fields: [moduleId], references: [id])
  title      String
  description String?
  credit     Int
  price     Float
  discount  Float
  isEnabled Boolean @default(true)
  allowedDomains String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items PlanItem[]
  @@map("plans")
}

model PlanItem {
  id        Int      @id @default(autoincrement())
  planId    Int
  plan      Plan     @relation(fields: [planId], references: [id])
  title      String
  @@map("plan_items")
}

enum ClientStatus {
  active
  inactive
}

enum PaymentType {
  rent
  buy
}

enum RentalAgreementStatus {
  active
  cancelled
}

enum InvoiceStatus {
  pending
  paid
  overdue
  cancelled
}
